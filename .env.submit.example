# Copy to .env.submit and fill in values from Google Cloud Console + OAuth Playground.
# .env.submit is gitignored — never commit real credentials.

# Chrome Web Store Developer Console → 新しいアイテムをアップロードすると発行される
CHROME_EXTENSION_ID=

# Google Cloud Console → 認証情報 → OAuth クライアント ID
CHROME_CLIENT_ID=
CHROME_CLIENT_SECRET=

# OAuth Playground で取得
# Scope: https://www.googleapis.com/auth/chromewebstore
CHROME_REFRESH_TOKEN=

# Optional: deploy strategy
# CHROME_PUBLISH_TARGET=default
